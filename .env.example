VITE_MINECRAFT_AU_SERVER_API=
VITE_MINECRAFT_SERVERS_JSON=

# SSH relay / Minecraft API runtime
MINECRAFT_ROOT=/mnt/storage-1/minecraft
MINECRAFT_SCRIPT_ROOT=/mnt/storage-1/minecraft/scripts
MINECRAFT_BACKUP_ROOT=/mnt/storage-1/minecraft/backups/snapshots
MINECRAFT_RCON_HOST=127.0.0.1
MINECRAFT_RCON_TIMEOUT_MS=10000
MINECRAFT_RCON_IDLE_MS=150
MINECRAFT_RCON_MAX_RESPONSE_BYTES=1048576
MINECRAFT_WAKE_TIMEOUT_MS=60000
MINECRAFT_ACTIVITY_LOG=/mnt/storage-1/minecraft/panel-activity.jsonl
MINECRAFT_ACTIVITY_READ_BYTES=2097152
MINECRAFT_MOD_UPLOAD_MAX_BYTES=134217728
MINECRAFT_ICON_CACHE_SECONDS=300
MINECRAFT_STATUS_STREAM_INTERVAL_MS=5000
MINECRAFT_MAINTENANCE_CRON=/etc/cron.d/minecraft
MINECRAFT_LOCAL_SNAPSHOT_RETENTION=2
MINECRAFT_DAILY_RESTART_HC=06:00
MINECRAFT_DAILY_RESTART_SHC=06:20
MINECRAFT_DAILY_RESTART_MC=06:40
MINECRAFT_API_DISABLE_AUTH=false
MINECRAFT_ADMIN_EMAILS=
MINECRAFT_ADMIN_UIDS=
MINECRAFT_GAME_VERSION_HC=1.21.11
MINECRAFT_GAME_VERSION_SHC=1.21.11
MINECRAFT_GAME_VERSION_MC=26.1.2
MINECRAFT_SERVERS_FILE=
